{
    "name": "carriagedb/crdt-php",
    "description": "Conflict-free Replicated Data Types (CRDT) for PHP.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "autoload": {
        "psr-4": {
            "CarriageDB\\CRDT\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Nathan Heffley",
            "email": "nathan@nathanheffley.com"
        }
    ],
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "scripts": {
        "fix:style": "phpcbf --standard=PSR12 src tests",
        "test:style": "phpcs --standard=PSR12 src tests",
        "test:types": "phpstan analyse -c phpstan.neon",
        "test:unit": "phpunit tests",
        "test": [
            "@test:style",
            "@test:types",
            "@test:unit"
        ]
    }
}
